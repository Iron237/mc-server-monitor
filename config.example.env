# Web service
APP_NAME=Minecraft Server Monitor
HOST=0.0.0.0
PORT=3000

# Optional bearer token. When set, /api/* requires:
#   Authorization: Bearer <AUTH_TOKEN>  OR  ?token=<AUTH_TOKEN>  OR  cookie mc_token=<AUTH_TOKEN>
# /health and the login asset stay public.
AUTH_TOKEN=

# Push status updates to the dashboard via Server-Sent Events (default on).
SSE_ENABLED=true

# Global polling
MC_PROTOCOL_VERSION=767
PING_TIMEOUT_MS=3500
POLL_INTERVAL_MS=15000
DATA_DIR=./data
HISTORY_LIMIT=240

# After this many polls without seeing a player in partial-tracking mode, the
# session is auto-closed so the leaderboard does not drift forever.
STALE_SESSION_POLL_MULTIPLIER=4

# ─── Server list ──────────────────────────────────────────────────────────────
# 推荐做法：把每个服务器的详细配置写到 servers.jsonc（多行、可注释、可尾逗号）。
# 复制模板：
#     cp servers.example.jsonc servers.jsonc
# 然后编辑 servers.jsonc，重启监控。
#
# 优先级：
#   1. SERVERS_FILE（下面这一行；显式指向某个 .jsonc/.json）
#   2. 项目根目录下的 servers.jsonc 或 servers.json（自动发现）
#   3. SERVERS=[...]   一行 JSON（向后兼容，不推荐继续用）
#   4. MC_HOST / MC_PORT 等单服务器变量（向后兼容，仅当上面都没设时启用）
#SERVERS_FILE=servers.jsonc

# 旧的 SERVERS 一行 JSON 仍然支持（向后兼容），但请优先用 servers.jsonc
#SERVERS=[{"id":"server1","name":"生存服","host":"127.0.0.1","port":25565,"queryEnabled":true,"queryPort":25565,"processPort":25565,"logBackfillEnabled":true,"logPath":"G:/logs"}]

LOG_BACKFILL_MAX_FILES=80
LOG_BACKFILL_MAX_SESSION_HOURS=24
RCON_TIMEOUT_MS=3000

# Alert: warn when TPS stays below this threshold continuously for at least
# ALERT_TPS_DURATION_MS milliseconds. Surfaces in the dashboard banner and
# pushes an `alert` SSE event. Brief blips that recover before the duration
# elapses do not fire.
ALERT_TPS_THRESHOLD=10
ALERT_TPS_DURATION_MS=300000

# World-folder size sampler. Walks the configured worldPath every interval
# and stores a (timestamp, bytes) point so the dashboard can show a growth
# curve and rough days-until-full prediction. Default: every hour, keep 30
# days of hourly samples.
WORLD_SIZE_INTERVAL_MS=3600000
WORLD_SIZE_HISTORY_LIMIT=720

# Webhook recipients for alerts / online-offline events. Prefer a JSONC file
# (cp webhooks.example.jsonc webhooks.jsonc) over the env var because the
# JSON gets unwieldy with multiple recipients.
#WEBHOOKS_FILE=webhooks.jsonc
WEBHOOK_TIMEOUT_MS=5000

# Single-server fallback (used only when no servers.jsonc / servers.json /
# SERVERS env is set):
# MC_HOST=127.0.0.1
# MC_PORT=25565
# MC_QUERY_ENABLED=false
# MC_QUERY_HOST=127.0.0.1
# MC_QUERY_PORT=25565
# MC_PROCESS_PID=
# MC_PROCESS_PORT=25565
# MC_PROCESS_NAME=java
# MC_LOG_BACKFILL_ENABLED=false
# MC_LOG_PATH=G:/临时处理
# MC_WORLD_PATH=
# MC_RCON_ENABLED=false
# MC_RCON_HOST=
# MC_RCON_PORT=0
# MC_RCON_PASSWORD=
