# Web service
APP_NAME=Minecraft Server Monitor
HOST=0.0.0.0
PORT=3000

# Minecraft server status ping
MC_HOST=127.0.0.1
MC_PORT=25565
MC_PROTOCOL_VERSION=767
PING_TIMEOUT_MS=3500
POLL_INTERVAL_MS=15000

# Enable this for accurate full online player lists and duration tracking.
# In server.properties, set:
# enable-query=true
# query.port=25565
MC_QUERY_ENABLED=false
MC_QUERY_HOST=127.0.0.1
MC_QUERY_PORT=25565

# Optional process resource view. For many servers this is java.
MC_PROCESS_NAME=java

# Runtime data
DATA_DIR=./data
HISTORY_LIMIT=240
