# Web service
APP_NAME=Minecraft Server Monitor
HOST=0.0.0.0
PORT=3000

# Global polling
MC_PROTOCOL_VERSION=767
PING_TIMEOUT_MS=3500
POLL_INTERVAL_MS=15000
DATA_DIR=./data
HISTORY_LIMIT=240

# Multiple server config. Server 2 defaults to port 2000 in this example.
# Resource matching priority per server:
# 1. pid: exact process id
# 2. processPort: process listening on this TCP port
# 3. processName: fallback process name
SERVERS=[{"id":"server1","name":"生存服","host":"127.0.0.1","port":25565,"queryEnabled":true,"queryHost":"127.0.0.1","queryPort":25565,"processPort":25565},{"id":"server2","name":"服务器2","host":"127.0.0.1","port":2000,"queryEnabled":true,"queryHost":"127.0.0.1","queryPort":2000,"processPort":2000}]

# If you do not set SERVERS, the old single-server variables still work:
# MC_HOST=127.0.0.1
# MC_PORT=25565
# MC_QUERY_ENABLED=false
# MC_QUERY_HOST=127.0.0.1
# MC_QUERY_PORT=25565
# MC_PROCESS_PID=
# MC_PROCESS_PORT=25565
# MC_PROCESS_NAME=java
